# ===== LLM 配置 =====
# 模型提供者: openai, ollama, anthropic, qwen, deepseek, zhipuai
LLM_PROVIDER=qwen

# OpenAI 配置
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# 阿里通义千问配置
QWEN_API_KEY=
QWEN_MODEL=

# Anthropic Claude 配置
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Deepseek 配置
DEEPSEEK_API_KEY=sk-a33b07bd48fd4ada9e32fc1af2761b38
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 智谱大模型配置 (https://open.bigmodel.cn/) - 使用 OpenAI 兼容 API
# 注意: 智谱最新 SDK (zai) 支持 OpenAI 兼容接口
ZHIPUAI_API_KEY=
ZHIPUAI_MODEL=glm-z1-flash
ZHIPUAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
ZHIPUAI_TEMPERATURE=0.6

# Ollama 本地模型配置
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ===== Embedding 配置 =====
# 💡 embedding 提供者选择（推荐配置）:
#   ⭐ bgem3        - 最佳效果！支持 Milvus 混合检索（Dense + Sparse）
#   1. huggingface  - 免费、本地、隐私、适合 ChromaDB
#   2. ollama       - 本地部署、离线运行
#   3. openai       - 需要 OpenAI API Key
#   4. deepseek     - 便宜，需要 Deepseek API Key
#   5. zhipuai      - 需要智谱 API Key
#   6. baichuan     - 需要百川 API Key

EMBEDDING_PROVIDER=bgem3 

# ===== HuggingFace Embedding 配置 ✅ 推荐 =====
# 特点：免费、本地运行、支持中英文
# 模型选项：moka-ai/m3e-base (推荐), bge-base-zh-v1.5, sentence-transformers/...
HUGGINGFACE_EMBEDDING_MODEL=moka-ai/m3e-base
# 计算设备：cpu (推荐), cuda (需要 GPU), mps (Mac GPU)
HUGGINGFACE_DEVICE=cpu

# ===== OpenAI Embedding 配置 =====
# 特点：付费、性能优秀、云端服务
# 需要配置 OPENAI_API_KEY 和 OPENAI_BASE_URL (见上方 LLM 配置)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# ===== Ollama Embedding 配置 =====
# 特点：本地部署、离线运行、无需 API Key
# 前提：已安装 Ollama 和相应模型
# 运行 Ollama: ollama pull nomic-embed-text
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434

# ===== Deepseek Embedding 配置 =====
# 特点：便宜、性能好、云端服务
# 需要配置 DEEPSEEK_API_KEY 和 DEEPSEEK_BASE_URL
DEEPSEEK_EMBEDDING_MODEL=text-embedding-3-small
DEEPSEEK_EMBEDDING_BASE_URL=https://api.deepseek.com/v1

# ===== Zhipuai 智谱 Embedding 配置 =====
# 特点：中文优化、与 GLM 模型配套
# 需要配置 ZHIPUAI_API_KEY (见上方 LLM 配置)
ZHIPUAI_EMBEDDING_MODEL=embedding-3

# ===== Baichuan 百川 Embedding 配置 =====
# 特点：中文优化、与百川模型配套、需要 API Key
BAICHUAN_EMBEDDING_KEY=your-baichuan-key

# ===== 数据库配置 (可选) =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=llm
DB_CHARSET=utf8mb4

# ===== 向量数据库配置 =====
# 向量数据库类型: chroma, milvus
VECTOR_DB_TYPE=milvus

# ChromaDB 配置（原有系统）
CHROMA_PERSIST_DIR=./chroma_db

# Milvus 配置（新增，推荐使用）
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=ai_bi_kb

# BGEM3 嵌入模型配置（用于 Milvus 混合检索）
# 模型路径：本地路径或 HuggingFace 模型名称
BGEM3_EMBEDDING_MODEL=BAAI/bge-m3
BGEM3_DENSE_DIM=1024
BGEM3_USE_FP16=True

# ===== RAG 优化配置 =====
# 启用相关性检查（过滤无关问题）
RAG_ENABLE_RELEVANCE_CHECK=True

# 启用查询转换（生成多个查询变体）
RAG_ENABLE_QUERY_TRANSFORM=True
RAG_QUERY_VARIANTS=3

# 启用 HyDE（假设文档扩展，可选）
RAG_ENABLE_HYDE=True

# 启用重排序（提高准确度）
RAG_ENABLE_RERANK=True

# 检索参数
RAG_TOP_K=2
RAG_SCORE_THRESHOLD=0.5

# ===== RAG 高级策略配置（TOP 5 推荐方案）=====
# 💡 策略模式选择（推荐优先级）:
#   - simple    : 基础向量搜索（最快，成本最低）⚡ 默认
#   - hybrid    : 融合检索 - 向量+BM25（推荐，平衡性能和成本）⭐⭐⭐⭐⭐
#   - enhanced  : 融合检索 + 上下文增强（高质量）⭐⭐⭐⭐
#   - adaptive  : 自适应策略 - 智能选择最优方法（智能，可能成本较高）⭐⭐⭐
#   - full      : 全流程优化（最高质量，成本最高）⭐⭐⭐⭐⭐

RAG_STRATEGY_MODE=simple

# 1. 融合检索 (Hybrid RAG) - 向量搜索 + BM25 关键词搜索
RAG_ENABLE_HYBRID=True
# 语义搜索权重（0-1），BM25权重 = 1 - 该值
RAG_HYBRID_SEMANTIC_WEIGHT=0.6
# 是否使用倒数排名融合（RRF），否则使用加权分数融合
RAG_HYBRID_USE_RRF=True

# 2. 上下文增强 (Context Enriched RAG) - 检索相邻文档块
RAG_ENABLE_CONTEXT_ENRICHED=True
# 上下文半径：前后各取N个块（0=不增强，1=前后各1块，2=前后各2块）
RAG_CONTEXT_RADIUS=1
# 是否将上下文合并到主块文本中
RAG_CONTEXT_MERGE=True

# 3. 自适应 RAG (Adaptive RAG) - 根据查询类型智能选择策略
RAG_ENABLE_ADAPTIVE=True
# 注意: 启用后会根据查询复杂度自动选择策略，可能增加成本

# ===== 文本处理配置 =====
# 启用文本清洗（去除页码、URL、页眉页脚等噪音）
TEXT_CLEANING_ENABLED=True

# 启用智能分割（自动检测文档结构并按语义分割）
# 支持：法规条款、章节、问答等格式
SMART_SPLIT_ENABLED=True

# 自定义清洗模式（逗号分隔的固定字符串）
# 例如：CUSTOM_CLEAN_PATTERNS=页眉文本,页脚文本,保密声明
CUSTOM_CLEAN_PATTERNS=

# ===== 应用配置 =====
DEBUG=False
LOG_LEVEL=INFO
